# Auto-detect text files and perform LF normalization
* text=auto

# Explicitly declare text files to always use LF line endings on checkout
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Explicitly declare binary files that should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
